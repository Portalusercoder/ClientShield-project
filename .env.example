# PostgreSQL connection string
# Local Docker development example only.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://clientshield_dev:clientshield_dev_password@localhost:5432/clientshield?schema=public"

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="ClientShield"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Authentication (placeholder — integrate production IdP later)
# AUTH_SECRET="generate-a-secure-random-string-for-production"
# AUTH_PROVIDER="none"

# OWASP ZAP (server-side only — never expose to the browser)
# Local compose binds ZAP API to 127.0.0.1:8090 with a required API key.
ZAP_API_URL="http://127.0.0.1:8090"
ZAP_API_KEY="change-me-clientshield-zap-dev-key"
# Required when host port ≠ container port (compose maps 8090→8080)
ZAP_API_HOST_HEADER="localhost:8080"
ZAP_SPIDER_MAX_MINUTES="1"
ZAP_SCAN_TIMEOUT_MS="300000"

# Wazuh read-only integration (server-side only — never NEXT_PUBLIC_*)
# Keep WAZUH_ENABLED=false until you are ready for the first manual sync.
WAZUH_ENABLED="false"
WAZUH_INDEXER_URL="https://127.0.0.1:9200"
WAZUH_INDEXER_USERNAME="admin"
WAZUH_INDEXER_PASSWORD="change-me"
WAZUH_MANAGER_API_URL="https://127.0.0.1:55000"
WAZUH_MANAGER_API_USERNAME="wazuh-wui"
WAZUH_MANAGER_API_PASSWORD="change-me"
# Path to the Wazuh Indexer root CA PEM
WAZUH_CA_CERT_PATH="/absolute/path/to/wazuh-docker/single-node/config/wazuh_indexer_ssl_certs/root-ca.pem"
# Manager API often presents a different self-signed cert (CN=wazuh.com, SAN=localhost).
# Extract public cert: openssl s_client -connect 127.0.0.1:55000 </dev/null | openssl x509 -out config/wazuh/manager-api-server.pem
WAZUH_MANAGER_CA_CERT_PATH="/absolute/path/to/ClientShield-project/config/wazuh/manager-api-server.pem"
WAZUH_INDEXER_TLS_SERVERNAME="wazuh.indexer"
WAZUH_MANAGER_TLS_SERVERNAME="localhost"
# ClientShield organization that owns ingested events (single-Wazuh local model)
WAZUH_ORGANIZATION_ID="cly00000000000000000000001"
WAZUH_CORRELATION_WINDOW_MINUTES="15"
# Minimum Wazuh rule level to create SecurityEvents (lower still ledgered)
WAZUH_MIN_EVENT_LEVEL="4"
# Optional comma-separated rule ID lists
WAZUH_RULE_ALLOWLIST=""
WAZUH_RULE_DENYLIST=""
WAZUH_SCA_CORRELATION_WINDOW_MINUTES="1440"
# Scheduled sync worker (default OFF — enable only after review)
WAZUH_AUTO_SYNC_ENABLED="false"
WAZUH_SYNC_INTERVAL_SECONDS="60"
# Optional: WAZUH_WORKER_ACTOR_USER_ID=""
# Optional: WAZUH_WORKER_ID=""

# Cross-event investigation correlation (post-ingestion; never blocks Wazuh sync)
INVESTIGATION_CORRELATION_ENABLED="true"
INVESTIGATION_CORRELATION_WINDOW_HOURS="24"
INVESTIGATION_CANDIDATE_MIN_CONFIDENCE="MEDIUM"
INVESTIGATION_SUGGESTION_MIN_CONFIDENCE="HIGH"
INVESTIGATION_MIN_ACTIONABLE_EVENTS="2"
INVESTIGATION_MIN_SIGNAL_FAMILIES="2"
INVESTIGATION_CANDIDATE_EXPIRY_HOURS="72"

# External threat intelligence (manual lookup only; default OFF)
THREAT_INTEL_ENABLED="false"
# Optional provider id when enabling (e.g. virustotal) — leave unset until configured
# THREAT_INTEL_PROVIDER=""
THREAT_INTEL_CACHE_HOURS="24"
