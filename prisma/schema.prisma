  incident     Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actor        User?        @relation("IncidentActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([incidentId])
  @@index([createdAt])
  @@index([incidentId, createdAt])
