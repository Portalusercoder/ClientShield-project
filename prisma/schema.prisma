// Prisma schema for ClientShield multi-tenant cybersecurity platform.
// Every business resource belongs directly or indirectly to an Organization.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

enum AssetType {
  WEBSITE
  WEB_APPLICATION
  API
  SERVER
  WORKSTATION
  NETWORK_DEVICE
  DOMAIN
  IOT_DEVICE
  OTHER
}

enum AssetCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetEnvironment {
  PRODUCTION
  STAGING
  DEVELOPMENT
  OTHER
}

enum AssetMonitoringStatus {
  ACTIVE
  PAUSED
  INACTIVE
}

enum AssetAuthorizationStatus {
  AUTHORIZED
  PENDING
  NOT_AUTHORIZED
}

enum ScanStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

enum FindingSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingStatus {
  OPEN
  VALIDATED
  IN_PROGRESS
  RESOLVED
  ACCEPTED_RISK
  FALSE_POSITIVE
}

enum FindingSource {
  PASSIVE_CHECK
  OWASP_ZAP
  MANUAL
  OTHER
}

/// Analyst urgency — distinct from scanner Severity.
enum TriagePriority {
  P1_CRITICAL
  P2_HIGH
  P3_MEDIUM
  P4_LOW
  P5_INFORMATIONAL
}

enum BusinessImpact {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum ExploitabilityAssessment {
  UNLIKELY
  POSSIBLE
  LIKELY
  UNKNOWN
}

enum RemediationComplexity {
  LOW
  MEDIUM
  HIGH
  UNKNOWN
}

/// How thoroughly the asset has been assessed by ClientShield checks.
enum AssessmentCoverage {
  LIMITED
  BASIC
}

enum RemediationStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum RemediationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  INVESTIGATING
  CONTAINED
  ERADICATED
  RECOVERING
  RESOLVED
  CLOSED
}

enum IncidentCategory {
  MALWARE
  PHISHING
  ACCOUNT_COMPROMISE
  UNAUTHORIZED_ACCESS
  BRUTE_FORCE
  DATA_EXPOSURE
  DATA_EXFILTRATION
  WEB_ATTACK
  DENIAL_OF_SERVICE
  VULNERABILITY_EXPLOITATION
  SUSPICIOUS_ACTIVITY
  POLICY_VIOLATION
  IOT_SECURITY
  OTHER
}

enum IncidentSource {
  MANUAL
  FINDING
  WAZUH
  OWASP_ZAP
  PASSIVE_CHECK
  OTHER
}

enum IncidentDetectionMethod {
  MANUAL
  SIEM
  EDR
  IDS_IPS
  VULNERABILITY_SCANNER
  WEB_MONITORING
  USER_REPORT
  OTHER
}

enum IncidentActivityType {
  CREATED
  ACKNOWLEDGED
  STATUS_CHANGED
  ASSIGNED
  SEVERITY_CHANGED
  NOTE_ADDED
  FINDING_LINKED
  FINDING_UNLINKED
  SECURITY_EVENT_LINKED
  SECURITY_EVENT_UNLINKED
  REMEDIATION_LINKED
  CONTAINMENT_UPDATED
  ERADICATION_UPDATED
  RECOVERY_UPDATED
  INVESTIGATION_UPDATED
  RESOLUTION_UPDATED
  LESSONS_UPDATED
  RESOLVED
  CLOSED
  REOPENED
  PLAYBOOK_ASSIGNED
  TASK_CREATED
  TASK_STATUS_CHANGED
  TASK_ASSIGNED
  EVIDENCE_ADDED
  COMMANDER_ASSIGNED
  LEAD_ANALYST_ASSIGNED
  POST_INCIDENT_UPDATED
}

enum PlaybookPhase {
  INVESTIGATION
  CONTAINMENT
  ERADICATION
  RECOVERY
  POST_INCIDENT
}

enum ResponseTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  COMPLETED
  SKIPPED
}

enum ResponseTaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum EvidenceType {
  SECURITY_EVENT
  FINDING
  LOG
  SCREENSHOT
  DOCUMENT
  FILE
  NOTE
  OTHER
}

enum SecurityEventSource {
  WAZUH
}

enum SecurityEventSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum SecurityEventStatus {
  NEW
  REVIEWING
  ACKNOWLEDGED
  ESCALATED
  DISMISSED
}

enum SecurityEventClassification {
  ACTIONABLE
  INFORMATIONAL
  NOISY
  IGNORED
}

enum SecurityEventActivityType {
  CREATED
  CORRELATED_OCCURRENCE
  REVIEW_STARTED
  ACKNOWLEDGED
  DISMISSED
  ESCALATED
  LINKED_TO_INCIDENT
  UNLINKED_FROM_INCIDENT
  CLASSIFICATION_CHANGED
}

enum WazuhProcessedDisposition {
  EVENT_CREATED
  EVENT_CORRELATED
  FILTERED_LEVEL
  FILTERED_DENYLIST
  FILTERED_ALLOWLIST
  MALFORMED
  DUPLICATE
}

enum ObservableType {
  IP_ADDRESS
  DOMAIN
  HOSTNAME
  URL
  FILE_HASH
  FILE_PATH
  PROCESS
  USERNAME
  EMAIL
  OTHER
}

enum ObservableRole {
  SOURCE
  DESTINATION
  SUBJECT
  PROCESS
  FILE
  NETWORK
  OTHER
}

enum CorrelationCandidateStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum CorrelationConfidence {
  LOW
  MEDIUM
  HIGH
}

enum InvestigationStatus {
  OPEN
  INVESTIGATING
  CONFIRMED
  DISMISSED
  LINKED_TO_INCIDENT
  CLOSED
}

enum InvestigationCreatedByType {
  SYSTEM_SUGGESTED
  ANALYST_CREATED
}

enum InvestigationActivityType {
  CREATED
  CANDIDATE_ACCEPTED
  CANDIDATE_REJECTED
  EVENT_ADDED
  EVENT_REMOVED
  INVESTIGATION_STARTED
  CONFIRMED
  DISMISSED
  THREAT_INTEL_LOOKUP
  LINKED_TO_INCIDENT
  INCIDENT_CREATED
  NOTE_ADDED
}

enum ThreatIntelLookupStatus {
  PENDING
  SUCCESS
  NOT_FOUND
  ERROR
}

enum ThreatIntelRiskLevel {
  UNKNOWN
  LOW
  MEDIUM
  HIGH
  MALICIOUS
}

enum ClientStatus {
  PROSPECT
  ONBOARDING
  ACTIVE
  SUSPENDED
  OFFBOARDED
  /// @deprecated Prefer OFFBOARDED. Kept for historical rows / compatibility.
  INACTIVE
}

enum ClientContactType {
  PRIMARY
  TECHNICAL
  SECURITY
  BILLING
  EXECUTIVE
  OTHER
}

enum ClientServiceType {
  PASSIVE_WEB_MONITORING
  ZAP_BASELINE
  WAZUH_ENDPOINT_MONITORING
  SECURITY_EVENT_MONITORING
  INCIDENT_RESPONSE
  REPORTING
}

enum ClientServiceStatus {
  PLANNED
  ACTIVE
  PAUSED
  DISABLED
}

enum ClientOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  READY
  COMPLETED
}

enum ClientOnboardingStep {
  CLIENT_PROFILE
  CONTACTS
  SECURITY_SCOPE
  ASSETS
  SERVICES
  AUTHORIZATION
  REVIEW
}

enum ClientUserAccessStatus {
  INVITED
  ACTIVE
  REVOKED
}

enum ClientUserAccessRole {
  CLIENT_VIEWER
  CLIENT_ADMIN
}

enum WazuhEnrollmentStatus {
  PENDING
  READY
  ENROLLING
  ENROLLED
  VERIFIED
  FAILED
  EXPIRED
  REVOKED
}

enum WazuhEnrollmentPlatform {
  MACOS
  WINDOWS
  LINUX
}

enum WazuhEnrollmentArch {
  ARM64
  X64
}

enum WazuhAgentMappingStatus {
  ACTIVE
  INACTIVE
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  clients          Client[]
  assets           Asset[]
  scans            Scan[]
  findings               Finding[]
  findingInstances       FindingInstance[]
  remediationTasks       RemediationTask[]
  securityScoreSnapshots SecurityScoreSnapshot[]
  incidents              Incident[]
  incidentActivities     IncidentActivity[]
  incidentNotes          IncidentNote[]
  incidentFindings       IncidentFinding[]
  incidentCaseSequences  IncidentCaseSequence[]
  incidentPlaybooks      IncidentPlaybook[]
  incidentPlaybookInstances IncidentPlaybookInstance[]
  incidentResponseTasks  IncidentResponseTask[]
  incidentEvidence       IncidentEvidence[]
  securityEvents         SecurityEvent[]
  securityEventActivities SecurityEventActivity[]
  wazuhAgentMappings     WazuhAgentMapping[]
  wazuhAgentEnrollments  WazuhAgentEnrollment[]
  wazuhIngestionStates   WazuhIngestionState[]
  wazuhProcessedAlerts   WazuhProcessedAlert[]
  incidentSecurityEvents IncidentSecurityEvent[]
  securityObservables    SecurityObservable[]
  securityEventObservables SecurityEventObservable[]
  correlationCandidates  CorrelationCandidate[]
  investigationGroups    InvestigationGroup[]
  investigationGroupEvents InvestigationGroupEvent[]
  investigationGroupIncidents InvestigationGroupIncident[]
  investigationActivities InvestigationActivity[]
  threatIntelLookups     ThreatIntelLookup[]
  iotDevices             IoTDevice[]
  reports                Report[]
  auditLogs              AuditLog[]
  organizationSettings   OrganizationSettings?
  clientContacts         ClientContact[]
  clientServices         ClientService[]
  clientOnboardings      ClientOnboarding[]
  clientUserAccesses     ClientUserAccess[]
  socAttentionStates     SocAttentionState[]
  socAttentionUserSnoozes SocAttentionUserSnooze[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  name           String?
  role           UserRole @default(VIEWER)
  /// External identity provider subject ID (Auth0, Clerk, Azure AD, etc.)
  externalId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization              Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedFindings          Finding[]         @relation("FindingAssignee")
  acceptedRiskFindings      Finding[]         @relation("FindingRiskApprover")
  validatedFindings         Finding[]         @relation("FindingValidator")
  assignedRemediationTasks  RemediationTask[] @relation("RemediationAssignee")
  createdReports            Report[]          @relation("ReportCreator")
  assignedIncidents         Incident[]        @relation("IncidentAssignee")
  createdIncidents          Incident[]        @relation("IncidentCreator")
  leadAnalystIncidents      Incident[]        @relation("IncidentLeadAnalyst")
  commanderIncidents        Incident[]        @relation("IncidentCommander")
  incidentActivities        IncidentActivity[] @relation("IncidentActivityActor")
  incidentNotes             IncidentNote[]    @relation("IncidentNoteAuthor")
  incidentFindingLinks      IncidentFinding[] @relation("IncidentFindingLinker")
  createdPlaybooks          IncidentPlaybook[] @relation("PlaybookCreator")
  assignedPlaybookInstances IncidentPlaybookInstance[] @relation("PlaybookInstanceAssigner")
  assignedResponseTasks     IncidentResponseTask[] @relation("ResponseTaskAssignee")
  completedResponseTasks    IncidentResponseTask[] @relation("ResponseTaskCompleter")
  createdResponseTasks      IncidentResponseTask[] @relation("ResponseTaskCreator")
  collectedEvidence         IncidentEvidence[] @relation("EvidenceCollector")
  securityEventsReviewed    SecurityEvent[]   @relation("SecurityEventReviewer")
  securityEventsDismissed   SecurityEvent[]   @relation("SecurityEventDismisser")
  securityEventActivities   SecurityEventActivity[] @relation("SecurityEventActivityActor")
  wazuhAgentMappings        WazuhAgentMapping[] @relation("WazuhAgentMapper")
  wazuhAgentEnrollmentsCreated WazuhAgentEnrollment[] @relation("WazuhEnrollmentCreator")
  incidentSecurityEventLinks IncidentSecurityEvent[] @relation("IncidentSecurityEventLinker")
  investigationGroupsCreated InvestigationGroup[] @relation("InvestigationGroupCreator")
  investigationActivities   InvestigationActivity[] @relation("InvestigationActivityActor")
  investigationGroupEventsAdded InvestigationGroupEvent[] @relation("InvestigationGroupEventAdder")
  threatIntelLookupsRequested ThreatIntelLookup[] @relation("ThreatIntelLookupRequester")
  correlationCandidatesReviewed CorrelationCandidate[] @relation("CorrelationCandidateReviewer")
  clientUserAccesses            ClientUserAccess[]     @relation("ClientUserAccessUser")
  attentionAcknowledged         SocAttentionState[]    @relation("AttentionAcknowledgedBy")
  attentionClaimed              SocAttentionState[]    @relation("AttentionClaimedBy")
  attentionSnoozes              SocAttentionUserSnooze[] @relation("AttentionSnoozeUser")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([externalId])
}

model OrganizationSettings {
  id                    String   @id @default(cuid())
  organizationId        String   @unique
  displayName           String?
  defaultTimezone       String?  @default("UTC")
  securityContactEmail  String?
  /// Non-secret report branding preferences (colors, footer text). Never store credentials.
  defaultReportBranding Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Client {
  id                  String       @id @default(cuid())
  organizationId      String
  name                String
  slug                String
  industry            String?
  website             String?
  country             String?
  timezone            String?
  primaryContactName  String?
  primaryContactEmail String?
  phone               String?
  notes               String?
  status              ClientStatus @default(ONBOARDING)
  securityScore       Float?
  onboardingStartedAt DateTime?
  activatedAt         DateTime?
  suspendedAt         DateTime?
  offboardedAt        DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets                 Asset[]
  incidents              Incident[]
  reports                Report[]
  findings               Finding[]
  securityScoreSnapshots SecurityScoreSnapshot[]
  securityEvents         SecurityEvent[]
  wazuhAgentMappings     WazuhAgentMapping[]
  wazuhAgentEnrollments  WazuhAgentEnrollment[]
  contacts               ClientContact[]
  services               ClientService[]
  onboarding             ClientOnboarding?
  userAccesses           ClientUserAccess[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
  @@index([industry])
}

/// Customer-company contact. Does NOT grant ClientShield login access.
model ClientContact {
  id             String            @id @default(cuid())
  organizationId String
  clientId       String
  name           String
  email          String
  phone          String?
  jobTitle       String?
  contactType    ClientContactType @default(OTHER)
  isPrimary      Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([clientId])
  @@index([organizationId, clientId, isPrimary])
}

/// Security capability offered to a Client. Enabling ≠ technical readiness.
model ClientService {
  id             String              @id @default(cuid())
  organizationId String
  clientId       String
  serviceType    ClientServiceType
  status         ClientServiceStatus @default(PLANNED)
  enabledAt      DateTime?
  disabledAt     DateTime?
  configuration  Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([organizationId, clientId, serviceType])
  @@index([organizationId])
  @@index([clientId])
  @@index([status])
}

model ClientOnboarding {
  id             String                 @id @default(cuid())
  organizationId String
  clientId       String                 @unique
  status         ClientOnboardingStatus @default(NOT_STARTED)
  currentStep    ClientOnboardingStep   @default(CLIENT_PROFILE)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

/// Future Client Portal access mapping. Do not auto-grant from ClientContact.
model ClientUserAccess {
  id             String                 @id @default(cuid())
  organizationId String
  clientId       String
  userId         String
  accessRole     ClientUserAccessRole   @default(CLIENT_VIEWER)
  status         ClientUserAccessStatus @default(INVITED)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user         User         @relation("ClientUserAccessUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, clientId, userId])
  @@index([organizationId])
  @@index([clientId])
  @@index([userId])
}

model Asset {
  id                  String                    @id @default(cuid())
  organizationId      String
  clientId            String
  name                String
  type                AssetType
  /// Full URL for web assets (nullable when hostname is used instead)
  url                 String?
  /// Hostname or IP for non-URL assets
  hostname            String?
  environment         AssetEnvironment          @default(PRODUCTION)
  criticality         AssetCriticality          @default(MEDIUM)
  monitoringStatus    AssetMonitoringStatus     @default(ACTIVE)
  /// Informational until active scanning is implemented.
  /// Active security testing must only be allowed when AUTHORIZED.
  authorizationStatus AssetAuthorizationStatus  @default(PENDING)
  description         String?
  securityScore       Float?
  lastSecurityCheckAt DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                 Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  scans                  Scan[]
  findings               Finding[]
  remediationTasks       RemediationTask[]
  iotDevices             IoTDevice[]
  securityScoreSnapshots SecurityScoreSnapshot[]
  incidents              Incident[]
  securityEvents         SecurityEvent[]
  wazuhAgentMappings     WazuhAgentMapping[]
  wazuhAgentEnrollments  WazuhAgentEnrollment[]

  @@index([organizationId])
  @@index([clientId])
  @@index([type])
  @@index([criticality])
  @@index([monitoringStatus])
  @@index([authorizationStatus])
}

model Scan {
  id             String     @id @default(cuid())
  organizationId String
  assetId        String
  status         ScanStatus @default(PENDING)
  /// Scan type identifier. Passiveive checks use PASSIVE_WEBSITE. ZAP uses ZAP_BASELINE.
  scanType       String
  startedAt      DateTime?
  completedAt    DateTime?
  durationMs     Int?
  overallScore   Float?
  /// Structured scan results. Never store secrets, cookies, or full sensitive bodies.
  summary        Json?
  errorMessage   String?
  /// Scanner product version when available (e.g. ZAP version string).
  scannerVersion String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset        Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  findings     Finding[]
  findingInstances FindingInstance[]

  @@index([organizationId])
  @@index([assetId])
  @@index([status])
  @@index([scanType])
}

model Finding {
  id                      String         @id @default(cuid())
  organizationId          String
  clientId                String?
  assetId                 String
  scanId                  String?
  source                  FindingSource  @default(PASSIVE_CHECK)
  /// Stable finding code for deduplication (e.g. HSTS_MISSING)
  code                    String?
  title                   String
  description             String?
  severity                FindingSeverity
  status                  FindingStatus  @default(OPEN)
  cvssScore               Float?
  cveId                   String?
  /// Sanitized technical evidence only. Never store secrets or cookie values.
  evidence                Json?
  remediationGuidance     String?
  firstDetectedAt         DateTime       @default(now())
  lastDetectedAt          DateTime       @default(now())
  resolvedAt              DateTime?
  assignedToUserId        String?
  dueDate                 DateTime?
  /// Required when status is FALSE_POSITIVE or ACCEPTED_RISK (also used for ZAP manual resolve notes)
  statusReason            String?
  acceptedRiskApprovedByUserId String?
  acceptedRiskApprovedAt  DateTime?
  /// Risk acceptance review / expiration date (UI: Review / Expiration Date)
  acceptedRiskReviewDate  DateTime?
  validatedAt             DateTime?
  validatedByUserId       String?
  validationNotes         String?
  analystNotes            String?
  triagePriority          TriagePriority?
  businessImpact          BusinessImpact?
  exploitabilityAssessment ExploitabilityAssessment?
  remediationComplexity   RemediationComplexity?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  organization             Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                   Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  asset                    Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  scan                     Scan?             @relation(fields: [scanId], references: [id], onDelete: SetNull)
  assignedTo               User?             @relation("FindingAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  acceptedRiskApprovedBy   User?             @relation("FindingRiskApprover", fields: [acceptedRiskApprovedByUserId], references: [id], onDelete: SetNull)
  validatedBy              User?             @relation("FindingValidator", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  remediationTasks         RemediationTask[]
  instances                FindingInstance[]
  incidentLinks            IncidentFinding[]

  @@index([organizationId])
  @@index([clientId])
  @@index([assetId])
  @@index([severity])
  @@index([status])
  @@index([source])
  @@index([code])
  @@index([assignedToUserId])
  @@index([dueDate])
  @@index([triagePriority])
  @@index([validatedByUserId])
  @@index([organizationId, assetId, code])
}

/**
 * Historical ClientShield Security Posture Score snapshots.
 * Used for trends; not a certification or guarantee of security.
 */
model SecurityScoreSnapshot {
  id             String              @id @default(cuid())
  organizationId String
  clientId       String?
  assetId        String?
  score          Float
  coverage       AssessmentCoverage?
  calculatedAt   DateTime            @default(now())
  reason         String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset        Asset?       @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([clientId])
  @@index([assetId])
  @@index([calculatedAt])
  @@index([organizationId, assetId, calculatedAt])
}

/**
 * Affected location for a Finding (primarily OWASP ZAP URL instances).
 * The parent Finding represents the underlying issue; instances are locations.
 */
model FindingInstance {
  id               String   @id @default(cuid())
  organizationId   String
  findingId        String
  scanId           String?
  /// Stable per-finding instance key: path + method + param
  instanceKey      String
  url              String?
  normalizedPath   String
  httpMethod       String?
  parameter        String?
  /// Sanitized location evidence only — never secrets/cookies/tokens.
  evidence         Json?
  firstDetectedAt  DateTime @default(now())
  lastDetectedAt   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  finding      Finding      @relation(fields: [findingId], references: [id], onDelete: Cascade)
  scan         Scan?        @relation(fields: [scanId], references: [id], onDelete: SetNull)

  @@unique([findingId, instanceKey])
  @@index([organizationId])
  @@index([findingId])
  @@index([scanId])
  @@index([normalizedPath])
  @@index([lastDetectedAt])
}

model RemediationTask {
  id               String              @id @default(cuid())
  organizationId   String
  findingId        String?
  assetId          String
  title            String
  description      String?
  notes            String?
  status           RemediationStatus   @default(OPEN)
  priority         RemediationPriority @default(MEDIUM)
  assignedToUserId String?
  dueDate          DateTime?
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  finding      Finding?     @relation(fields: [findingId], references: [id], onDelete: SetNull)
  asset        Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation("RemediationAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([assetId])
  @@index([findingId])
  @@index([status])
  @@index([assignedToUserId])
  @@index([dueDate])
}

model Incident {
  id                      String                   @id @default(cuid())
  organizationId          String
  clientId                String
  assetId                 String?
  /// Human-readable case id: INC-YYYY-NNNNNN (unique per organization)
  caseNumber              String
  title                   String
  description             String?
  severity                IncidentSeverity
  status                  IncidentStatus           @default(OPEN)
  category                IncidentCategory         @default(OTHER)
  source                  IncidentSource           @default(MANUAL)
  /// External system identifier (e.g. future Wazuh alert id). Never trust as auth.
  externalSourceId        String?
  detectionMethod         IncidentDetectionMethod  @default(MANUAL)
  occurredAt              DateTime?
  detectedAt              DateTime                 @default(now())
  reportedAt              DateTime                 @default(now())
  acknowledgedAt          DateTime?
  investigationStartedAt  DateTime?
  containedAt             DateTime?
  eradicatedAt            DateTime?
  recoveringAt            DateTime?
  resolvedAt              DateTime?
  closedAt                DateTime?
  declaredAt              DateTime?
  assignedToUserId        String?
  leadAnalystUserId       String?
  commanderUserId         String?
  createdByUserId         String?
  businessImpact          String?
  technicalImpact         String?
  impactSummary           String?
  scopeSummary            String?
  rootCause               String?
  containmentSummary      String?
  eradicationSummary      String?
  recoverySummary         String?
  resolutionSummary       String?
  lessonsLearned          String?
  whatWentWell            String?
  whatCouldImprove        String?
  followUpActions         String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset        Asset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignedTo   User?              @relation("IncidentAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  leadAnalyst  User?              @relation("IncidentLeadAnalyst", fields: [leadAnalystUserId], references: [id], onDelete: SetNull)
  commander    User?              @relation("IncidentCommander", fields: [commanderUserId], references: [id], onDelete: SetNull)
  createdBy    User?              @relation("IncidentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  activities   IncidentActivity[]
  notes        IncidentNote[]
  findings     IncidentFinding[]
  securityEvents IncidentSecurityEvent[]
  playbookInstances IncidentPlaybookInstance[]
  responseTasks IncidentResponseTask[]
  evidence     IncidentEvidence[]
  investigationGroupIncidents InvestigationGroupIncident[]
  reports      Report[]

  @@unique([organizationId, caseNumber])
  @@index([organizationId])
  @@index([clientId])
  @@index([assetId])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([source])
  @@index([assignedToUserId])
  @@index([leadAnalystUserId])
  @@index([commanderUserId])
  @@index([detectedAt])
  @@index([organizationId, status])
  @@index([organizationId, externalSourceId])
}

model IncidentCaseSequence {
  id             String @id @default(cuid())
  organizationId String
  year           Int
  lastValue      Int    @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, year])
  @@index([organizationId])
}

model IncidentPlaybook {
  id                String            @id @default(cuid())
  /// Null = system template available to all orgs
  organizationId    String?
  name              String
  description       String?
  category          IncidentCategory?
  severity          IncidentSeverity?
  isActive          Boolean           @default(true)
  isSystemTemplate  Boolean           @default(false)
  createdByUserId   String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  organization Organization?              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?                      @relation("PlaybookCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  steps        PlaybookStep[]
  instances    IncidentPlaybookInstance[]

  @@index([organizationId])
  @@index([isSystemTemplate])
  @@index([isActive])
  @@index([category])
