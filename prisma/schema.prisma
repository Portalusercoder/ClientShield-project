model PlaybookStep {
  id              String               @id @default(cuid())
  playbookId      String
  order           Int
  phase           PlaybookPhase
  title           String
  description     String?
  isRequired      Boolean              @default(true)
  defaultPriority ResponseTaskPriority @default(MEDIUM)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  playbook IncidentPlaybook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@index([playbookId])
  @@index([playbookId, order])
}

model IncidentPlaybookInstance {
  id                String   @id @default(cuid())
  organizationId    String
  incidentId        String
  sourcePlaybookId  String?
  playbookName      String
  assignedAt        DateTime @default(now())
  assignedByUserId  String?

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident     Incident               @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  sourcePlaybook IncidentPlaybook?    @relation(fields: [sourcePlaybookId], references: [id], onDelete: SetNull)
  assignedBy   User?                  @relation("PlaybookInstanceAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  tasks        IncidentResponseTask[]

  @@index([organizationId])
  @@index([incidentId])
  @@index([sourcePlaybookId])
}

model IncidentResponseTask {
  id                 String               @id @default(cuid())
  organizationId     String
  incidentId         String
  playbookInstanceId String?
  phase              PlaybookPhase
  title              String
  description        String?
  priority           ResponseTaskPriority @default(MEDIUM)
  status             ResponseTaskStatus   @default(TODO)
  isRequired         Boolean              @default(true)
  assignedToUserId   String?
  dueAt              DateTime?
  completedAt        DateTime?
  completedByUserId  String?
  completionNote     String?
  blockedReason      String?
  skipReason         String?
  createdByUserId    String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident         Incident                 @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  playbookInstance IncidentPlaybookInstance? @relation(fields: [playbookInstanceId], references: [id], onDelete: SetNull)
  assignedTo       User?                    @relation("ResponseTaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  completedBy      User?                    @relation("ResponseTaskCompleter", fields: [completedByUserId], references: [id], onDelete: SetNull)
  createdBy        User?                    @relation("ResponseTaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([incidentId])
  @@index([playbookInstanceId])
  @@index([status])
  @@index([phase])
  @@index([assignedToUserId])
  @@index([organizationId, incidentId])
}

model IncidentEvidence {
  id                String       @id @default(cuid())
  organizationId    String
  incidentId        String
  type              EvidenceType
  title             String
  description       String?
  /// e.g. "SECURITY_EVENT" | "FINDING" | "NOTE"
  sourceType        String?
  sourceReferenceId String?
