model IncidentNote {
  id             String   @id @default(cuid())
  organizationId String
  incidentId     String
  authorUserId   String
  content        String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident     Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author       User         @relation("IncidentNoteAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([incidentId])
  @@index([createdAt])
}

model IncidentFinding {
  id             String   @id @default(cuid())
  organizationId String
  incidentId     String
  findingId      String
  linkedByUserId String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident     Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  finding      Finding      @relation(fields: [findingId], references: [id], onDelete: Cascade)
  linkedBy     User?        @relation("IncidentFindingLinker", fields: [linkedByUserId], references: [id], onDelete: SetNull)

  @@unique([incidentId, findingId])
  @@index([organizationId])
  @@index([incidentId])
  @@index([findingId])
}

model SecurityEvent {
  id                 String                @id @default(cuid())
  organizationId     String
  clientId           String?
  assetId            String?
  source             SecurityEventSource   @default(WAZUH)
  /// Primary Wazuh document id for the latest contributing alert (display/reference).
  externalEventId    String?
  ruleId             String?
  ruleLevel          Int?
  ruleDescription    String?
  ruleGroups         Json?
  agentId            String?
  agentName          String?
  severity           SecurityEventSeverity
  status             SecurityEventStatus   @default(NEW)
  classification     SecurityEventClassification @default(ACTIONABLE)
  title              String
  summary            String?
  firstSeenAt        DateTime
  lastSeenAt         DateTime
  occurrenceCount    Int                   @default(1)
  correlationKey     String
  /// Human-readable explanation of why alerts were grouped (never expose hash as primary UX).
  correlationSummary String?
  /// Optional SCA check / policy identifier used for correlation.
  scaCheckId         String?
  sourceIp           String?
  destinationIp      String?
  sourcePort         Int?
  destinationPort    Int?
  protocol           String?
  /// Optional host/process context extracted from sanitized Wazuh data fields.
  username           String?
  processName        String?
  filePath           String?
  commandLine        String?
  mitreTactics       Json?
  mitreTechniques    Json?
  pciDss             Json?
  gdpr               Json?
  hipaa              Json?
  nist               Json?
  rawDataSanitized   Json?
  reviewedAt         DateTime?
  reviewedByUserId   String?
  acknowledgedAt     DateTime?
  dismissedAt        DateTime?
  dismissedByUserId  String?
  dismissalReason    String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?                  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  asset        Asset?                   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  reviewedBy   User?                    @relation("SecurityEventReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  dismissedBy  User?                    @relation("SecurityEventDismisser", fields: [dismissedByUserId], references: [id], onDelete: SetNull)
  incidents    IncidentSecurityEvent[]
  processedAlerts WazuhProcessedAlert[]
  activities   SecurityEventActivity[]
  observables  SecurityEventObservable[]
  correlationCandidatesAsA CorrelationCandidate[] @relation("CorrelationEventA")
  correlationCandidatesAsB CorrelationCandidate[] @relation("CorrelationEventB")
  investigationGroupEvents InvestigationGroupEvent[]

  @@index([organizationId])
  @@index([clientId])
  @@index([assetId])
  @@index([status])
  @@index([severity])
  @@index([classification])
  @@index([source])
  @@index([ruleId])
  @@index([agentId])
  @@index([lastSeenAt])
  @@index([organizationId, correlationKey])
  @@index([organizationId, status])
  @@index([organizationId, lastSeenAt])
  @@index([organizationId, classification])
}

model SecurityEventActivity {
  id              String                    @id @default(cuid())
  organizationId  String
  securityEventId String
  actorUserId     String?
  activityType    SecurityEventActivityType
  message         String
  note            String?
  metadata        Json?
  createdAt       DateTime                  @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  securityEvent SecurityEvent @relation(fields: [securityEventId], references: [id], onDelete: Cascade)
  actor         User?         @relation("SecurityEventActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([securityEventId])
  @@index([createdAt])
  @@index([securityEventId, createdAt])
  @@index([securityEventId, activityType])
}

model IncidentSecurityEvent {
  id              String   @id @default(cuid())
  organizationId  String
  incidentId      String
  securityEventId String
  linkedByUserId  String?
  createdAt       DateTime @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident      Incident      @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  securityEvent SecurityEvent @relation(fields: [securityEventId], references: [id], onDelete: Cascade)
  linkedBy      User?         @relation("IncidentSecurityEventLinker", fields: [linkedByUserId], references: [id], onDelete: SetNull)

  @@unique([incidentId, securityEventId])
  @@index([organizationId])
  @@index([incidentId])
  @@index([securityEventId])
}

model WazuhAgentMapping {
  id               String    @id @default(cuid())
  organizationId   String
  wazuhAgentId     String
  wazuhAgentName   String?
  clientId         String?
  assetId          String?
  lastKnownStatus  String?
  lastSeenAt       DateTime?
  mappedByUserId   String?
  /// ACTIVE mappings resolve SecurityEvents; INACTIVE preserves history after offboard/remap.
  status           WazuhAgentMappingStatus @default(ACTIVE)
  inactiveAt       DateTime?
  inactiveReason   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  asset        Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  mappedBy     User?        @relation("WazuhAgentMapper", fields: [mappedByUserId], references: [id], onDelete: SetNull)
  enrollments  WazuhAgentEnrollment[]

  @@unique([organizationId, wazuhAgentId])
  @@index([organizationId])
  @@index([clientId])
  @@index([assetId])
  @@index([status])
}

/// Application-layer remote endpoint enrollment. Does not store Wazuh secrets.
model WazuhAgentEnrollment {
  id                 String                   @id @default(cuid())
  organizationId     String
  clientId           String
  assetId            String
  agentName          String
  expectedHostname   String
  platform           WazuhEnrollmentPlatform
  architecture       WazuhEnrollmentArch
  status             WazuhEnrollmentStatus    @default(PENDING)
  /// Non-secret connectivity hint only (e.g. "Tailscale overlay — manager on VPN IP"). Never credentials.
  connectionHint     String?
  requestedAt        DateTime                 @default(now())
  expiresAt          DateTime
  enrolledAt         DateTime?
  verifiedAt         DateTime?
  revokedAt          DateTime?
  wazuhAgentId       String?
  mappingId          String?
  createdByUserId    String?
  /// Sanitized operator-facing error; never secrets.
  lastErrorSanitized String?
  hostnameMismatch   Boolean                  @default(false)
  observedHostname   String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset        Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy    User?              @relation("WazuhEnrollmentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  mapping      WazuhAgentMapping? @relation(fields: [mappingId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([clientId])
  @@index([assetId])
  @@index([status])
  @@index([expiresAt])
  @@index([wazuhAgentId])
}

model WazuhIngestionState {
  id                   String    @id @default(cuid())
  organizationId       String    @unique
  lastTimestamp        DateTime?
  lastDocumentId       String?
  lastSuccessfulSyncAt DateTime?
  lastAttemptAt        DateTime?
  lastError            String?
  /// Cross-process sync lease holder (manual UI or worker id).
  lockedBy             String?
  lockedAt             DateTime?
  lockExpiresAt        DateTime?
  /// Background worker heartbeat (optional).
  workerId             String?
  workerLastHeartbeatAt DateTime?
  /// Last sync counters (overwrite each run; not historical fabrications).
  lastSyncDurationMs   Int?
  lastSyncProcessed    Int?
  lastSyncCreated      Int?
  lastSyncUpdated      Int?
  lastSyncFiltered     Int?
  lastSyncIgnored      Int?
  lastSyncSkippedDuplicates Int?
  lastSyncErrors       Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// Idempotency ledger for processed Wazuh Indexer documents.
model WazuhProcessedAlert {
  id              String                    @id @default(cuid())
  organizationId  String
  documentId      String
  securityEventId String?
  alertTimestamp  DateTime?
  disposition     WazuhProcessedDisposition?
  filterReason    String?
  createdAt       DateTime                  @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  securityEvent SecurityEvent? @relation(fields: [securityEventId], references: [id], onDelete: SetNull)

  @@unique([organizationId, documentId])
  @@index([organizationId])
  @@index([securityEventId])
  @@index([organizationId, createdAt])
  @@index([disposition])
}

/**
 * Org-scoped IOC / observable extracted from security events.
 * normalizedValue is the canonical form used for matching within an organization.
 */
model SecurityObservable {
  id              String         @id @default(cuid())
  organizationId  String
  type            ObservableType
  /// Original display value (sanitized; never secrets).
  value           String
  /// Canonical form for uniqueness / correlation (lowercase IP, domain, etc.).
  normalizedValue String
  firstSeenAt     DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventLinks   SecurityEventObservable[]
  threatIntelLookups ThreatIntelLookup[]

  @@unique([organizationId, type, normalizedValue])
  @@index([organizationId])
  @@index([type])
  @@index([organizationId, type])
  @@index([lastSeenAt])
}

model SecurityEventObservable {
  id              String         @id @default(cuid())
  organizationId  String
  securityEventId String
  observableId    String
  role            ObservableRole @default(OTHER)
  createdAt       DateTime       @default(now())

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  securityEvent SecurityEvent     @relation(fields: [securityEventId], references: [id], onDelete: Cascade)
  observable    SecurityObservable @relation(fields: [observableId], references: [id], onDelete: Cascade)

  @@unique([securityEventId, observableId, role])
  @@index([organizationId])
  @@index([securityEventId])
  @@index([observableId])
}

/**
 * Cross-event correlation suggestion (distinct from Wazuh occurrence correlation).
 * eventAId < eventBId is enforced in the service layer for the unique constraint.
 */
model CorrelationCandidate {
  id                   String                     @id @default(cuid())
  organizationId       String
  eventAId             String
  eventBId             String
  score                Int
  confidence           CorrelationConfidence
  /// Human-readable reason strings explaining the score.
  reasons              Json
  /// Signal families that contributed (ASSET_CONTEXT, NETWORK, …).
  signalFamilies       Json?
  /// Extra quality/risk notes for analysts.
  qualityFactors       Json?
  status               CorrelationCandidateStatus @default(PENDING)
  investigationGroupId String?
  reviewedByUserId     String?
  reviewedAt           DateTime?
  rejectReason         String?
  expiresAt            DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventA             SecurityEvent      @relation("CorrelationEventA", fields: [eventAId], references: [id], onDelete: Cascade)
  eventB             SecurityEvent      @relation("CorrelationEventB", fields: [eventBId], references: [id], onDelete: Cascade)
  investigationGroup InvestigationGroup? @relation(fields: [investigationGroupId], references: [id], onDelete: SetNull)
  reviewedBy         User?              @relation("CorrelationCandidateReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, eventAId, eventBId])
  @@index([organizationId])
  @@index([eventAId])
  @@index([eventBId])
  @@index([status])
  @@index([confidence])
  @@index([organizationId, status])
  @@index([investigationGroupId])
  @@index([expiresAt])
  @@index([organizationId, status, expiresAt])
}

model InvestigationGroup {
  id                   String                      @id @default(cuid())
  organizationId       String
  clientId             String?
  assetId              String?
  title                String
  summary              String?
  status               InvestigationStatus         @default(OPEN)
  severity             IncidentSeverity            @default(MEDIUM)
  createdByType        InvestigationCreatedByType
  createdByUserId      String?
  /// Human-readable explanation of why events were grouped.
  groupingExplanation  String?
  /// Aggregate confidence from correlation quality model (nullable for older rows).
  confidence           CorrelationConfidence?
  /// Deterministic fingerprint for SYSTEM_SUGGESTED deduplication.
  fingerprint          String?
  /// Cached quality metrics (event/rule/actionable counts, etc.).
  qualitySummary       Json?
  /// Analyst-facing warning when quality falls below current policy.
  qualityWarning       String?
  mitreTactics         Json?
  mitreTechniques      Json?
  confirmedAt          DateTime?
  dismissedAt          DateTime?
  dismissReason        String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  organization Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?                       @relation("InvestigationGroupCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  events       InvestigationGroupEvent[]
  incidents    InvestigationGroupIncident[]
  activities   InvestigationActivity[]
  correlationCandidates CorrelationCandidate[]

  @@index([organizationId])
  @@index([status])
  @@index([severity])
  @@index([createdByType])
  @@index([organizationId, status])
  @@index([createdAt])
  @@index([fingerprint])
  @@index([organizationId, fingerprint])
}

model InvestigationGroupEvent {
  id              String    @id @default(cuid())
  organizationId  String
  groupId         String
  securityEventId String
  addedByUserId   String?
  addedAt         DateTime  @default(now())
  /// Why this event was linked (correlation reason / analyst note).
  addReason       String?
  removedAt       DateTime?
  removeReason    String?

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group         InvestigationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  securityEvent SecurityEvent     @relation(fields: [securityEventId], references: [id], onDelete: Cascade)
  addedBy       User?             @relation("InvestigationGroupEventAdder", fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@unique([groupId, securityEventId])
  @@index([organizationId])
  @@index([groupId])
  @@index([securityEventId])
}

model InvestigationGroupIncident {
  id             String   @id @default(cuid())
  organizationId String
  groupId        String
  incidentId     String
  linkedByUserId String?
  createdAt      DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group        InvestigationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  incident     Incident          @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@unique([groupId, incidentId])
  @@index([organizationId])
  @@index([groupId])
  @@index([incidentId])
}

model InvestigationActivity {
  id             String                    @id @default(cuid())
  organizationId String
  groupId        String
  actorUserId    String?
  activityType   InvestigationActivityType
  message        String
  note           String?
  metadata       Json?
  createdAt      DateTime                  @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group        InvestigationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actor        User?             @relation("InvestigationActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([groupId])
  @@index([createdAt])
  @@index([groupId, createdAt])
}

model ThreatIntelLookup {
  id                    String                   @id @default(cuid())
  organizationId        String
  observableId          String
  provider              String
  status                ThreatIntelLookupStatus  @default(PENDING)
  riskLevel             ThreatIntelRiskLevel?
  confidence            Float?
  summary               String?
  /// Sanitized provider response — never store secrets or full raw bodies with PII dumps.
  rawResponseSanitized  Json?
  lookedUpAt            DateTime                 @default(now())
  expiresAt             DateTime?
  requestedByUserId     String?
  createdAt             DateTime                 @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  observable   SecurityObservable @relation(fields: [observableId], references: [id], onDelete: Cascade)
  requestedBy  User?             @relation("ThreatIntelLookupRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([observableId])
  @@index([provider])
  @@index([status])
  @@index([organizationId, observableId, provider])
  @@index([expiresAt])
}

model IoTDevice {
  id              String    @id @default(cuid())
  organizationId  String
  assetId         String?
  name            String
  deviceType      String?
  firmwareVersion String?
  ipAddress       String?
  isOnline        Boolean   @default(false)
  lastSeenAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset        Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([assetId])
}

enum ReportType {
  EXECUTIVE_SUMMARY
  SECURITY_POSTURE
  TECHNICAL_FINDINGS
  REMEDIATION_STATUS
  INCIDENT_CASE
}

enum ReportStatus {
  DRAFT
  GENERATING
  READY
  FAILED
  ARCHIVED
}

model Report {
  id                   String       @id @default(cuid())
  organizationId       String
  clientId             String
  incidentId           String?
  createdByUserId      String?
  reportType           ReportType   @default(SECURITY_POSTURE)
  title                String
  reportingPeriodStart DateTime
  reportingPeriodEnd   DateTime
  status               ReportStatus @default(DRAFT)
  generatedAt          DateTime?
  /// Immutable structured snapshot used for preview/PDF. Never mutate after READY.
  generatedData        Json?
  fileName             String?
  /// Storage key relative to report storage root — never a user-supplied path.
  storageKey           String?
  version              Int          @default(1)
  errorSummary         String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  incident     Incident?    @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("ReportCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([clientId])
  @@index([incidentId])
  @@index([status])
  @@index([reportType])
  @@index([generatedAt])
  @@index([organizationId, clientId, reportType])
}


model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  action         String
  resourceType   String
  resourceId     String?
  actorId        String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
  @@index([resourceType])
}

/// Shared SOC acknowledgement / overlay claim for the derived attention queue.
/// Queue eligibility remains derived from source records — this never resurrects ineligible sources.
enum AttentionSourceType {
  SECURITY_EVENT
  FINDING
  INVESTIGATION
  INCIDENT
}

model SocAttentionState {
  id                    String              @id @default(cuid())
  organizationId        String
  sourceType            AttentionSourceType
  sourceId              String
  /// Stable generation fingerprint for the source identity (not updatedAt-based).
  eligibilityGeneration String
  acknowledgedAt        DateTime?
  acknowledgedByUserId  String?
  /// Authoritative only for SECURITY_EVENT and INVESTIGATION overlay claims.
  claimedByUserId       String?
  claimedAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  acknowledgedBy User?        @relation("AttentionAcknowledgedBy", fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)
  claimedBy      User?        @relation("AttentionClaimedBy", fields: [claimedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, sourceType, sourceId, eligibilityGeneration])
  @@index([organizationId])
  @@index([organizationId, acknowledgedAt])
  @@index([organizationId, claimedByUserId])
  @@index([organizationId, sourceType, sourceId])
  @@index([acknowledgedByUserId])
  @@index([claimedByUserId])
}

/// Per-analyst personal snooze — does not hide items from other analysts or dashboard counts.
model SocAttentionUserSnooze {
  id                    String              @id @default(cuid())
  organizationId        String
  userId                String
  sourceType            AttentionSourceType
  sourceId              String
  eligibilityGeneration String
  snoozedAt             DateTime            @default(now())
  snoozedUntil          DateTime
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("AttentionSnoozeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, sourceType, sourceId, eligibilityGeneration])
  @@index([userId, snoozedUntil])
  @@index([organizationId, snoozedUntil])
  @@index([organizationId, userId])
}
